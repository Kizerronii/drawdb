#!/usr/bin/env bash
# drawdb — CLI do zarządzania lokalną instancją drawdb (studio wrapper).
# Instalacja: ./install.sh
set -euo pipefail

SCRIPT_PATH="$(readlink -f "$0")"
TOOL_DIR="$(dirname "$(dirname "$SCRIPT_PATH")")"
COMPOSE_FILE="$TOOL_DIR/compose-studio.yml"

if [[ ! -f "$COMPOSE_FILE" ]]; then
    echo "Błąd: nie znaleziono $COMPOSE_FILE" >&2
    exit 1
fi

COMPOSE=(docker compose -f "$COMPOSE_FILE")

PORT_PROD=3000
PORT_DEV=5173
PORT_API=3001
URL_PROD="http://localhost:$PORT_PROD"
URL_DEV="http://localhost:$PORT_DEV"
URL_API="http://localhost:$PORT_API"

WORKSPACE="${DRAWDB_WORKSPACE:-$HOME/drawdb-projects}"

_running() {
    docker ps --filter "name=^${1}\$" --filter status=running --format '{{.Names}}' | grep -q "^${1}\$"
}

_ensure_workspace() {
    if [[ ! -d "$WORKSPACE" ]]; then
        echo "→ Tworzenie workspace: $WORKSPACE"
        mkdir -p "$WORKSPACE"
    fi
}

_wait_for() {
    local url="$1" name="$2"
    local i
    for i in {1..40}; do
        if curl -sf "$url" >/dev/null 2>&1; then
            return 0
        fi
        sleep 0.25
    done
    echo "Ostrzeżenie: $name nie odpowiada na $url po ~10s" >&2
    return 1
}

_has_api_flag() {
    for arg in "$@"; do
        [[ "$arg" == "--api" ]] && return 0
    done
    return 1
}

cmd_up() {
    if _has_api_flag "$@"; then
        _ensure_workspace
        echo "→ Uruchamianie drawdb (prod, port $PORT_PROD) + api (port $PORT_API, profile api)..."
        "${COMPOSE[@]}" --profile api up -d drawdb drawdb-api
        echo "   $URL_PROD"
        echo "   $URL_API/api/health"
    else
        echo "→ Uruchamianie drawdb (prod, port $PORT_PROD, FSA storage)..."
        "${COMPOSE[@]}" up -d drawdb
        echo "   $URL_PROD"
        echo "   storage: File System Access API (frontend → dysk bezpośrednio)"
    fi
}

cmd_dev() {
    if _has_api_flag "$@"; then
        _ensure_workspace
        echo "→ Uruchamianie drawdb (dev, port $PORT_DEV, hot-reload) + api (port $PORT_API, profile api)..."
        "${COMPOSE[@]}" --profile dev --profile api up -d drawdb-dev drawdb-api
        echo "   $URL_DEV"
        echo "   $URL_API/api/health"
    else
        echo "→ Uruchamianie drawdb (dev, port $PORT_DEV, hot-reload, FSA storage)..."
        "${COMPOSE[@]}" --profile dev up -d drawdb-dev
        echo "   $URL_DEV"
        echo "   storage: File System Access API (frontend → dysk bezpośrednio)"
    fi
}

cmd_down() {
    echo "→ Zatrzymywanie drawdb..."
    "${COMPOSE[@]}" --profile dev --profile api down
}

cmd_restart() {
    local mode="${1:-prod}"
    shift || true
    cmd_down
    if [[ "$mode" == "dev" ]]; then
        cmd_dev "$@"
    else
        cmd_up "$@"
    fi
}

cmd_status() {
    local found=0
    for name in drawdb drawdb-dev drawdb-api; do
        if _running "$name"; then
            docker ps --filter "name=^${name}\$" --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'
            found=1
        fi
    done
    if [[ $found -eq 0 ]]; then
        echo "drawdb nie jest uruchomiony. Użyj: drawdb up"
    fi
}

cmd_logs() {
    "${COMPOSE[@]}" --profile dev logs "$@"
}

cmd_rebuild() {
    echo "→ Rebuild obrazów (--no-cache) drawdb + drawdb-api..."
    "${COMPOSE[@]}" build --no-cache drawdb drawdb-api
    cmd_down
    cmd_up
}

cmd_update() {
    echo "→ Pobieranie zmian z upstream drawdb-io/drawdb..."
    cd "$TOOL_DIR"
    if ! git remote get-url upstream >/dev/null 2>&1; then
        echo "Błąd: brak remote 'upstream' w $TOOL_DIR" >&2
        echo "Dodaj: git -C $TOOL_DIR remote add upstream https://github.com/drawdb-io/drawdb.git" >&2
        exit 1
    fi
    git fetch upstream
    local branch
    branch="$(git rev-parse --abbrev-ref HEAD)"
    echo "→ Merge upstream/main do lokalnego $branch..."
    git merge upstream/main
    cmd_rebuild
}

cmd_open() {
    if _running drawdb; then
        xdg-open "$URL_PROD" >/dev/null 2>&1
    elif _running drawdb-dev; then
        xdg-open "$URL_DEV" >/dev/null 2>&1
    else
        echo "drawdb nie jest uruchomiony. Użyj: drawdb up" >&2
        exit 1
    fi
}

# Otwiera drawdb w Chromium app mode (okno bez UI przeglądarki, jak natywna apka).
# Auto-startuje kontenery jeśli nie działają. setsid + disown odpina proces od terminala —
# możesz zamknąć terminal i drawdb żyje dalej.
cmd_launch() {
    # parsing: pierwsza pozycja może być 'dev' lub flag (--keep-terminal). Default = prod.
    local mode="prod"
    if [[ "${1:-}" == "dev" ]]; then
        mode="dev"
    fi
    local url

    if [[ "$mode" == "dev" ]]; then
        if ! _running drawdb-dev; then cmd_dev; fi
        url="$URL_DEV"
    else
        if ! _running drawdb; then cmd_up; fi
        url="$URL_PROD"
    fi

    _wait_for "$url" "drawdb ($mode)" || true

    if ! command -v chromium >/dev/null 2>&1; then
        echo "Brak chromium. Zainstaluj: sudo pacman -S chromium" >&2
        echo "Fallback do xdg-open: $url" >&2
        xdg-open "$url"
        return 0
    fi

    echo "→ Uruchamianie drawdb w Chromium app mode ($url)..."
    setsid chromium \
        --app="$url" \
        --new-window \
        --class="drawdb-studio" \
        --user-data-dir="$HOME/.local/share/drawdb-studio/chromium-profile" \
        >/dev/null 2>&1 < /dev/null &
    disown
    echo "   Window class: drawdb-studio (target dla Hyprland window rules)"

    # Domyślnie zamykamy okno terminala (efekt "podmianki" terminal → drawdb).
    # Wyłącz: drawdb launch [dev] --keep-terminal  lub  KEEP_TERMINAL=1 drawdb launch
    local keep_terminal=0
    for arg in "$@"; do
        [[ "$arg" == "--keep-terminal" ]] && keep_terminal=1
    done
    if [[ $keep_terminal -eq 1 || "${KEEP_TERMINAL:-}" == "1" ]]; then
        return 0
    fi
    sleep 0.3  # daj chromium chwilę na fork — żeby tiling miał gdzie wstawić nowe okno
    if command -v hyprctl >/dev/null 2>&1; then
        hyprctl dispatch killactive >/dev/null 2>&1 || true
    elif command -v xdotool >/dev/null 2>&1; then
        xdotool getactivewindow windowclose 2>/dev/null || true
    fi
}

cmd_sh() {
    local name="${1:-drawdb}"
    if ! _running "$name"; then
        echo "Kontener '$name' nie działa." >&2
        exit 1
    fi
    docker exec -it "$name" sh
}

cmd_help() {
    cat <<EOF
drawdb — CLI do zarządzania lokalną instancją drawdb (studio)

Użycie: drawdb <komenda> [args]

Komendy:
  up [--api]         Uruchom drawdb (prod, port $PORT_PROD).
                     --api: dorzuć kontener REST (port $PORT_API, legacy/MCP).
  dev [--api]        Uruchom drawdb (dev, port $PORT_DEV, hot-reload).
                     --api: jw.
  down               Zatrzymaj drawdb (wszystkie kontenery)
  restart [dev] [--api]
                     Restart (domyślnie prod, 'dev' uruchamia dev mode).
  launch [dev] [--keep-terminal]
                     Uruchom drawdb w Chromium app mode (bez UI przeglądarki) +
                     zamknij okno terminala (efekt "podmianki"). --keep-terminal pomija zamknięcie.
  status             Status kontenerów (drawdb, drawdb-dev, drawdb-api)
  logs [flagi]       Logi (przekazuje flagi do 'docker compose logs', np. -f)
  rebuild            Pełny rebuild obrazów (--no-cache) + restart
  update             Fetch + merge upstream/main + rebuild
  open               Otwórz drawdb w przeglądarce (xdg-open, auto-detect prod/dev)
  sh [name]          Shell w kontenerze (drawdb | drawdb-dev | drawdb-api)
  help               Ta pomoc

Storage:              File System Access API (default).
                      Pliki *.drawdb.json zapisywane w dowolnym miejscu — wybiera
                      user przez Save As. Apka pamięta ostatnio otwarte (recent).
                      --api używa REST + workspace folder ($WORKSPACE, legacy/MCP).
Tool dir:             $TOOL_DIR
Compose file:         $COMPOSE_FILE
EOF
}

case "${1:-help}" in
    up|dev|down|status|open|help|sh) cmd_"$1" "${@:2}" ;;
    restart) cmd_restart "${@:2}" ;;
    launch)  cmd_launch "${@:2}" ;;
    logs)    cmd_logs "${@:2}" ;;
    rebuild) cmd_rebuild ;;
    update)  cmd_update ;;
    *)
        echo "Nieznana komenda: $1" >&2
        echo "" >&2
        cmd_help >&2
        exit 1
        ;;
esac
